{
  "Diagnostics": {
    "LogSources": {
      "ronflow-centralized-api": {
        "Provider": "OpenSearch",
        "DisplayName": "RonFlow API centralized logs",
        "Centralized": {
          "Endpoint": "http://localhost:9200",
          "IndexPattern": "ronflow-logs-*",
          "QueryPattern": "message:*",
          "ServiceName": "ronflow-api",
          "Environment": "localhost",
          "TimeRangeMinutes": 120,
          "MaxTailLines": 500
        }
      },
      "ronauth-centralized-api": {
        "Provider": "OpenSearch",
        "DisplayName": "RonAuth API centralized logs",
        "Centralized": {
          "Endpoint": "http://localhost:9200",
          "IndexPattern": "ronflow-logs-*",
          "QueryPattern": "message:*",
          "ServiceName": "ronauth-api",
          "Environment": "localhost",
          "TimeRangeMinutes": 120,
          "MaxTailLines": 500
        }
      },
      "database-git-sync-centralized": {
        "Provider": "OpenSearch",
        "DisplayName": "Database Git sync centralized logs",
        "Centralized": {
          "Endpoint": "http://localhost:9200",
          "IndexPattern": "ronflow-logs-*",
          "QueryPattern": "message:*",
          "ServiceName": "database-git-sync",
          "Environment": "localhost",
          "TimeRangeMinutes": 120,
          "MaxTailLines": 500
        }
      },
      "ronflow-centralized-sample": {
        "Provider": "OpenSearch",
        "DisplayName": "RonFlow centralized sample logs",
        "Centralized": {
          "Endpoint": "http://localhost:9200",
          "IndexPattern": "ronflow-logs-*",
          "QueryPattern": "message:*",
          "ServiceName": "ronflow-sample",
          "Environment": "localhost",
          "TimeRangeMinutes": 120,
          "MaxTailLines": 100
        }
      }
    }
  }
}
